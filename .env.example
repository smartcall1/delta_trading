# ═══ 텔레그램 ═══
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══ 트레이딩 ═══
LEVERAGE=3
PAIRS=ETH
ENTRY_CHUNKS=10
EXIT_CHUNKS=10

# ═══ 보유 ═══
MIN_HOLD_MINUTES=30
MAX_HOLD_DAYS=2
COOLDOWN_MINUTES=5

# ═══ 리스크 ═══
MARGIN_EMERGENCY_PCT=10
SPREAD_OPPORTUNISTIC_USD=30
PRINCIPAL_BUFFER_USD=45

# ═══ 심볼 매핑 (거래소별) ═══
# 형식: PAIR:EXCHANGE_SYMBOL (콤마 구분)
SYMBOL_MAP_DANGO=ETH:perp/ethusd,BTC:perp/btcusd,SOL:perp/solusd,HYPE:perp/hypeusd
SYMBOL_MAP_STANDX=ETH:ETH-USD,BTC:BTC-USD,SOL:SOL-USD
SYMBOL_MAP_HIBACHI=ETH:ETH/USDT-P,BTC:BTC/USDT-P,SOL:SOL/USDT-P,HYPE:HYPE/USDT-P
SYMBOL_MAP_GRVT=ETH:ETH_USDT_Perp,BTC:BTC_USDT_Perp,SOL:SOL_USDT_Perp

# ═══ Tick Size (거래소별) ═══
# GRVT는 SDK 내부에서 자동 처리 — 설정 불필요
TICK_SIZE_DANGO=ETH:0.01,BTC:0.1,SOL:0.001,HYPE:0.001
TICK_SIZE_STANDX=ETH:0.01,BTC:0.1,SOL:0.001
